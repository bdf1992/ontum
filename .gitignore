# cache, never truth (§14.1): a fold over .ai-native/log/ — rebuilt by replay
.ai-native/queues/
.ai-native/offsets/
# ephemeral runtime coordination: the inference admission semaphore's slot
# leases (done-line 0149). Live-only, self-healing, never history.
.ai-native/inference-slots/
.ai-native/inbox.html
causality/welcome.html
causality/welcome-preview.png

# sensor trace, not truth: the command watcher's log (done-line 0011) — deletable
.ai-native/log/tool-use.jsonl

# tick journal, not truth: the workflow tenders' (.claude/workflows/) compiled
# per-tick drafts — propose-grain assist a session reads, never the verdicts.
# The truth is the log the value-confirm drain advances; this is deletable.
.ai-native/log/tenders.jsonl

# sensor trace: what Codex really hands a hook (done-line 0029) — deletable
.ai-native/log/codex-hook-probe.jsonl

# run trace, not truth: each headless gate run's prompt + raw output + stderr +
# exit code (done-line 0138) — debug cache so a failed run is visible, deletable
.ai-native/log/gate-runs/

# nag tally, not truth: turns the same mock set has sat (done-line 0033) —
# the still-mock set is a fold over the log; this only counts the pressure
.ai-native/mock-shame.json

# nag tally, not truth: turns the same unsurfaced owner-ask set has sat
# (done-line 0058) — the unsurfaced set is a fold over reports + the log
.ai-native/owner-ask-shame.json

# nag high-water mark, not truth: per-session count of denied trespasses
# (tooth #3) — the attempts themselves are witnessed on the watch log
.ai-native/trespass-shame.json

# session-ephemeral nag state, not truth (done-line 0135, the session-
# lifecycle organ): the patrol's escalate marker (escalate_armed/reason), the
# idle reminder's gap clock + decay count, and the continue-probe's per-session
# fire trace. Runtime state the hooks rewrite, sibling of mock-shame; the work
# the probe nudges toward is a fold over the log. (The retired continue-beat's
# .ai-native/continue-beat.json is kept ignored below so stray copies stay out.)
.ai-native/patrol.json
.ai-native/idle-reminder.json
.ai-native/log/continue-probe-fires.jsonl

# session-ephemeral UI state, not truth: each session's last-seen open set
# and last-poll clock for the standing-surface projection (done-line 0071) —
# the surface is the truth; this only remembers what was last shown, to tick
# up a change once without re-spamming. Per-session, deletable.
.ai-native/standing-state.json

# envoy packages are rebuildable artifacts (done-line 0015); the
# environment doc and the disclosure ledger are the committed trace
exports/*
!exports/CLAUDE.md
!exports/log.jsonl

__pycache__/
*.pyc

# Jekyll/Pages build output — rebuilt from source on every `jekyll build`
# and by the Pages workflow; never truth, never tracked.
_site/

# retired (done-line 0135): the continue-beat's old per-session state file —
# kept ignored so any stray copy on an old worktree never lands as truth.
.ai-native/continue-beat.json
