# cache, never truth (§14.1): a fold over .ai-native/log/ — rebuilt by replay
.ai-native/queues/
.ai-native/offsets/
.ai-native/inbox.html
causality/welcome.html
causality/welcome-preview.png

# sensor trace, not truth: the command watcher's log (done-line 0011) — deletable
.ai-native/log/tool-use.jsonl

# sensor trace: what Codex really hands a hook (done-line 0029) — deletable
.ai-native/log/codex-hook-probe.jsonl

# nag tally, not truth: turns the same mock set has sat (done-line 0033) —
# the still-mock set is a fold over the log; this only counts the pressure
.ai-native/mock-shame.json

# nag tally, not truth: turns the same unsurfaced owner-ask set has sat
# (done-line 0058) — the unsurfaced set is a fold over reports + the log
.ai-native/owner-ask-shame.json

# nag tally, not truth: the continue-beat / patrol's per-session beat count
# and escalate marker (session_id / beats / escalate_armed) — runtime state
# the hook rewrites each turn, sibling of mock-shame / owner-ask-shame.
.ai-native/continue-beat.json

# session-ephemeral UI state, not truth: each session's last-seen open set
# and last-poll clock for the standing-surface projection (done-line 0071) —
# the surface is the truth; this only remembers what was last shown, to tick
# up a change once without re-spamming. Per-session, deletable.
.ai-native/standing-state.json

# envoy packages are rebuildable artifacts (done-line 0015); the
# environment doc and the disclosure ledger are the committed trace
exports/*
!exports/CLAUDE.md
!exports/log.jsonl

__pycache__/
*.pyc

# Jekyll/Pages build output — rebuilt from source on every `jekyll build`
# and by the Pages workflow; never truth, never tracked.
_site/

# session-ephemeral nag state, not truth: the continue-beat's per-session
# beat count + escalate marker (done-line 0127) — the work it nudges toward
# is a fold over the log; this only holds the patrol's count and stand-down
.ai-native/continue-beat.json
