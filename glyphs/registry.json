      "non_example": "A center that sits deaf while its cells pull",
      "source": "docs/phase-2/ontum-evolution.md:178"
    },
    {
      "term": "Metafinitude",
      "status": "MINTED",
      "referent": "Relation between finite spec and infinite output, layers untouching",
      "non_example": "A large-but-bounded set",
      "source": "docs/phase-2/ontum-evolution.md:179"
    },
    {
      "term": "etymontoken",
      "status": "SETTLED",
