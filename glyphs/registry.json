  "terms": [
    {
      "term": "Ontum",
      "status": "SETTLED",
      "referent": "The unit; computational-presence atom; pluralizes to *onta",
      "non_example": "A passive storage byte",
      "source": "docs/phase-2/ontum-evolution.md:174"
    },
    {
      "term": "onta",
      "status": "SETTLED",
      "referent": "Plural of ontum; scale-recursively, the constituents that settle into an ontum",
      "non_example": "A single ontum viewed alone",
      "source": "docs/phase-2/ontum-evolution.md:175"
    },
    {
      "term": "Keystone",
      "status": "SETTLED",
      "referent": "The center cell / Token of an ontum; frame-relative, correction-bearing",
      "non_example": "An inert unweighted centroid (a dead token)",
      "source": "docs/phase-2/ontum-evolution.md:176"
    },
    {
      "term": "Jective",
