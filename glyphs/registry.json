    {
      "term": "Site",
      "status": "SETTLED",
      "referent": "A primitive treated as a local frame; holds its local stalk (with dynamics), an inward encoding, axis/antipode structure, and outgoing maps. Simultaneously a whole and a part.",
      "non_example": "A global object authored as its own file",
      "source": "docs/phase-2/autojective-polysheaf.md:37"
    },
    {
      "term": "Seam",
      "status": "SETTLED",
      "referent": "A primitive that is a join. Connects Sites and carries the comparison between them as a cocycle. A Seam that does not close is not a bug; it is data.",
      "non_example": "A boolean joined/not-joined flag",
      "source": "docs/phase-2/autojective-polysheaf.md:39"
    },
    {
      "term": "Atlas",
      "status": "SETTLED",
      "referent": "Not authored. The emergent index: the collection of Sites and Seams plus their incidence. The whole is read off the Atlas, never written as its own file.",
