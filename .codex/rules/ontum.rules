# .codex/rules/ontum.rules - generated by fence/render_codex.py; never hand-edit.
# The registry is fence/policy.py (done-line 0027); edit there and re-render:
#     python fence/render_codex.py
# Test a command against this file:
#     codex execpolicy check --pretty --rules .codex/rules/ontum.rules -- git add .

prefix_rule(
    pattern = ["git", "add"],
    decision = "forbidden",
    justification = "Raw `git add` is denied here (done-line 0020): the fleet shares one tree, and a sweep stages another session's work. Staging goes through the git pen, named paths only: python .claude/skills/branch-ritual/git.py add <path> <path>.",
    match = [
        "git add .",
        "git add -A",
        "git add loop/reconcile.py",
    ],
    not_match = [
        "git status",
        "git diff",
    ],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "forbidden",
    justification = "Raw `git commit` is denied here (done-line 0020): commits are branded through the git pen - python .claude/skills/branch-ritual/git.py commit -m \"<what landed>\" [paths] - named paths, a real message, never the trunk.",
    match = [
        "git commit -m wip",
        "git commit -am wip",
    ],
    not_match = [
        "git log -1",
        "git commit-tree HEAD^{tree}",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "forbidden",
    justification = "Raw `git push` is denied here (done-line 0014): nothing leaves the machine unchecked. The branded push is python .claude/skills/branch-ritual/pr.py push - it checks the branch is still alive and the suite is green (or declared red) first. Pushing main is never a session act: bdo confirms arcs and the independent merge-node lands confirmed PRs (D-4).",
    match = [
        "git push",
        "git push origin main",
        "git push -u origin claude/x",
    ],
    not_match = [
        "git fetch origin",
        "git pull",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "forbidden",
    justification = "Raw `gh pr create` is denied here (branch-ritual): every PR to main carries a validated story. The pen scaffolds and checks it: python .claude/skills/branch-ritual/pr.py create ... (-h lists the required fields).",
    match = [
        "gh pr create --title t --body b",
    ],
    not_match = [
        "gh pr view 7888",
        "gh pr list",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "edit"],
    decision = "forbidden",
    justification = "Raw `gh pr edit` is denied here (branch-ritual): reshape the story through the pen - python .claude/skills/branch-ritual/pr.py edit <number> ...",
    match = [
        "gh pr edit 12 --body x",
    ],
    not_match = [
        "gh pr view 12",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "forbidden",
    justification = "Raw `gh pr merge` is denied: main lands only through the independent merge-node, via the pen, after bdo confirms the arc (D-4). A piece-PR into an epic branch goes through the pen: python .claude/skills/branch-ritual/pr.py integrate <n> (it refuses a main base; done-line 0029).",
    match = [
        "gh pr merge 12 --squash",
    ],
    not_match = [
        "gh pr checks 12",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["close", "reopen"]],
    decision = "forbidden",
    justification = "Denied: opening and closing PRs is ritual work - surface it to bdo instead of doing it raw.",
    match = [
        "gh pr close 12",
        "gh pr reopen 12",
    ],
    not_match = [
        "gh pr view 12",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "review"],
    decision = "forbidden",
    justification = "Denied: no one signs their own line (D-2) - a session does not review or approve PRs.",
    match = [
        "gh pr review 12 --approve",
    ],
    not_match = [
        "gh pr diff 12",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "ready"],
    decision = "forbidden",
    justification = "Raw `gh pr ready` is denied here (done-line 0017): the draft flip IS the merge signal - it goes through the pen: python .claude/skills/branch-ritual/pr.py ready <n> (or python .claude/skills/branch-ritual/pr.py unready <n> to roll back).",
    match = [
        "gh pr ready 12",
    ],
    not_match = [
        "gh pr view 12",
    ],
)

prefix_rule(
    pattern = ["git", "checkout"],
    decision = "prompt",
    justification = "The repo root is bdo's VIEWPORT on main, and a worker edits only its OWN workstation (its worktree). The workstation fence (done-line 0145, command_guard) makes this LAW for Claude: a tree/HEAD flip in the viewport is FORBIDDEN; the same command in your worktree is fine. Make a workstation - git worktree add -b claude/<slug> ../ontum-wt/<slug> origin/main - and run there; to move the viewport to the trunk use the git pen (git.py sync), which fast-forwards and never flips. Approve only in your worktree.",
    match = [
        "git checkout main",
        "git checkout -b codex/x",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "prompt",
    justification = "The repo root is bdo's VIEWPORT on main, and a worker edits only its OWN workstation (its worktree). The workstation fence (done-line 0145, command_guard) makes this LAW for Claude: a tree/HEAD flip in the viewport is FORBIDDEN; the same command in your worktree is fine. Make a workstation - git worktree add -b claude/<slug> ../ontum-wt/<slug> origin/main - and run there; to move the viewport to the trunk use the git pen (git.py sync), which fast-forwards and never flips. Approve only in your worktree.",
    match = [
        "git switch main",
    ],
    not_match = [
        "git branch --list",
    ],
)

prefix_rule(
    pattern = ["git", ["merge", "rebase", "cherry-pick", "revert", "am", "apply"]],
    decision = "prompt",
    justification = "Integrating or rewriting commits (merge/rebase/cherry-pick/revert/am/apply) reshapes history. In the shared fleet tree that belongs inside your own worktree (../ontum-wt/<slug>; AGENTS.md), never the viewport on main - and trunk integration is the independent merge-node's after bdo confirms the arc (D-4), never a session's. Approve only inside your worktree.",
    match = [
        "git merge origin/main",
        "git rebase main",
        "git cherry-pick abc123",
    ],
    not_match = [
        "git status",
        "git log --oneline",
    ],
)

prefix_rule(
    pattern = ["git", ["reset", "restore", "clean", "stash"]],
    decision = "prompt",
    justification = "Discarding or shelving working state (reset/restore/clean/stash) can destroy uncommitted work. The doctrine asks for a reversible alternative before a destructive git op - commit, or stash with intent, first - and approve only with the loss in view.",
    match = [
        "git reset --hard HEAD",
        "git restore .",
        "git clean -fd",
        "git stash",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", ["rm", "mv"]],
    decision = "prompt",
    justification = "`git rm` / `git mv` stage a delete or rename. Staging goes through the git pen, named paths only (python .claude/skills/branch-ritual/git.py add <path>); approve a raw rm/mv only inside your worktree.",
    match = [
        "git rm old.py",
        "git mv a.py b.py",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "branch", ["-d", "-D", "-m", "-M", "-c", "-C", "--delete", "--move", "--copy"]],
    decision = "prompt",
    justification = "Deleting, moving, or copying a branch is fleet topology \u2014 in the shared tree it can strand unpushed work. Sessions branch off main into their own worktree (../ontum-wt/<slug>; AGENTS.md); approve only for your own worktree. Read-only `git branch`, `git branch --show-current`, and `git branch --list` are not topology \u2014 they pass, the introspection a session needs to know where it is.",
    match = [
        "git branch -d old",
        "git branch -D feature",
        "git branch -m old new",
        "git branch --delete old",
        "git branch --move old new",
        "git branch -C a b",
    ],
    not_match = [
        "git branch",
        "git branch --show-current",
        "git branch --list",
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "worktree", ["add", "remove", "prune", "repair", "move"]],
    decision = "prompt",
    justification = "Adding, removing, pruning, repairing, or moving a worktree is fleet topology. A session provisions its own worktree off main (../ontum-wt/<slug>; AGENTS.md) and approves only for that. Read-only `git worktree list [--porcelain]` is introspection \u2014 it passes, so a session can see the fleet's worktrees.",
    match = [
        "git worktree add ../wt/x",
        "git worktree remove ../wt/x",
        "git worktree prune",
        "git worktree move ../a ../b",
    ],
    not_match = [
        "git worktree list",
        "git worktree list --porcelain",
    ],
)

prefix_rule(
    pattern = ["gh", "issue", ["create", "edit", "close", "reopen", "comment", "delete", "lock", "unlock", "pin", "unpin", "transfer", "develop"]],
    decision = "prompt",
    justification = "Issues are bdo's surface. The reflector pen mirrors the owner's stamp queue onto GitHub automatically (.claude/skills/reflect/reflect.py) and the gate opens its own run-issue through its pen - a session does not open, close, or comment on issues raw. Surface the intent to bdo instead.",
    match = [
        "gh issue close 3",
        "gh issue comment 5 --body x",
        "gh issue create --title t --body b",
    ],
    not_match = [
        "gh issue view 3",
        "gh issue list",
    ],
)

prefix_rule(
    pattern = ["gh", "api", "-X", ["POST", "PUT", "PATCH", "DELETE", "post", "put", "patch", "delete"]],
    decision = "prompt",
    justification = "`gh api -X POST|PUT|PATCH|DELETE` writes straight to GitHub's API - bdo's surface, reached raw. A GET (the default) is a read and is fine; a write goes through a pen or is surfaced to bdo. (The watcher's classifier also tags `-f`/`--field` writes that omit `-X`, so the report sees them even when this prefix does not.)",
    match = [
        "gh api -X POST repos/o/r/issues",
        "gh api -X DELETE repos/o/r/issues/1",
    ],
    not_match = [
        "gh api user",
        "gh api -X GET repos/o/r",
    ],
)
