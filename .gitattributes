# One eol on every platform: source is stored and checked out LF.
* text=auto eol=lf

# Identity is sha256 over file bytes (atoms, logs, receipts). Git must
# never rewrite these at any boundary — eol conversion here orphans the
# pipeline history (it did, 2026-06-10: autocrlf turned the atoms CRLF
# and the fold read every atom as unborn).
.ai-native/** -text
*.jsonl -text

# The term-economy projection is a byte-deterministic fold artifact
# (done-line 0060): re-running term_economy.py must reproduce it exactly,
# so its bytes are pinned like the log's — never eol-rewritten.
causality/examples/*.json -text

# Rendered diagrams are byte-deterministic compose.py artifacts
# (epic.diagram, done-line 0139): the §10 test pins the committed SVG to
# a fresh render, so its bytes must never be eol-rewritten.
diagrams/examples/*.svg -text

# Append-only logs: parallel branches only ever append; union-merge
# keeps both tails instead of conflicting.
.ai-native/log/*.jsonl merge=union
exports/log.jsonl merge=union
