{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/command_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/spawn_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/spawn_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/write_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/command_guard.py --post",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/spawn_guard.py --post",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/spawn_guard.py --post",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m loop.summon --hook",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python .claude/skills/branch-ritual/git.py sync --hook",
            "timeout": 45
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/reflect_auto.py",
            "timeout": 150
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m loop.summon --hook",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
